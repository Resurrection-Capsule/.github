<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!-- Copy to the root of any repo that consumes org packages (e.g. the server, the Hub).
       Credentials are NOT stored here. CI injects them via the env var
       NuGetPackageSourceCredentials_github (Username=actions;Password=GITHUB_TOKEN).
       Local dev: set that same env var, or register the github source with a PAT
       (scope read:packages). See RELEASING.md for the exact command. -->

  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/Resurrection-Capsule/index.json" />
  </packageSources>

  <!-- Pin org packages to the org feed; everything else from nuget.org. Required by Central
       Package Management with multiple sources (NU1507) and prevents dependency confusion. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <package pattern="RakNexus" />
      <package pattern="AssetData.Parser*" />
      <package pattern="ReCap.*" />
    </packageSource>
  </packageSourceMapping>

</configuration>
